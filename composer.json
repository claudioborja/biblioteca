{
    "name": "biblioteca/biblioteca",
    "description": "Sistema de gestión de biblioteca",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "phpoffice/phpspreadsheet": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Core\\": "app/Core/",
            "Controllers\\": "app/Controllers/",
            "Services\\": "app/Services/",
            "Repositories\\": "app/Repositories/",
            "Models\\": "app/Models/",
            "Middleware\\": "app/Middleware/",
            "Enums\\": "app/Enums/",
            "Helpers\\": "app/Helpers/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
